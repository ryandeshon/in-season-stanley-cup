# Cypress test mode - uses mocked API endpoints
VUE_APP_NHL_API_URL=http://localhost:3000/nhl
VUE_APP_API_BASE=http://localhost:3000/api
# Empty WebSocket URL prevents connection attempts in tests
VUE_APP_WEB_SOCKET_URL=""
VUE_APP_ENABLE_SEASON_CONTRACTS=true

# Force these to empty to prevent .env or .env.local from overriding
VITE_API_BASE=http://localhost:3000/api
